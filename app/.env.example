# Server
PORT=4000
NODE_ENV=development

# Postgres (system of record)
DATABASE_URL=postgres://localhost:5432/ems
TEST_DATABASE_URL=postgres://localhost:5432/ems_test

# Redis (cache only; falls back to in-memory if unset/unreachable)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=15

# Auth
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# Audit S3 log shipping (mocked in prototype)
AUDIT_S3_SHIPPING_ENABLED=false
AUDIT_S3_BUCKET=ems-audit-logs

# Attachments / bill uploads
# STORAGE_DRIVER=local stores uploaded bills on disk (default); s3 is the
# documented production path. UPLOADS_DIR is where the local driver writes.
ATTACHMENTS_S3_BUCKET=ems-attachments
STORAGE_DRIVER=local
UPLOADS_DIR=var/uploads
MAX_UPLOAD_MB=5
